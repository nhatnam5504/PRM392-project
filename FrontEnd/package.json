{
  "name": "mss301",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "cypress:component": "cypress run --component",
    "cypress:e2e": "cypress run --e2e",
    "cypress:open": "cypress open",
    "dev": "vite --port 3000",
    "format": "prettier --write .",
    "generate-schema": "pnpm run generate-schema:orders && pnpm run generate-schema:products && pnpm run generate-schema:users",
    "generate-schema:orders": "pnpm exec openapi-typescript https://tgdd-api.kdz.asia/api/orders/v3/api-docs -o ./schema-orders.d.ts",
    "generate-schema:products": "pnpm exec openapi-typescript https://tgdd-api.kdz.asia/api/products/v3/api-docs -o ./schema-products.d.ts",
    "generate-schema:users": "pnpm exec openapi-typescript https://tgdd-api.kdz.asia/api/users/v3/api-docs -o ./schema-users.d.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck": "tsc -b"
  },
